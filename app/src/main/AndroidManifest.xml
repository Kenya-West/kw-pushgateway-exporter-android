<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Required: HTTP(S) push to Pushgateway -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Required: Check network connectivity for scheduling constraints -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Required: Collect Wi-Fi metrics (SSID, RSSI, link speed) -->
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />

    <!-- Required: Re-schedule jobs and start exporter after device reboot -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Optional: Telephony operator info; only if user enables telephony metrics.
         This is a dangerous permission on API 23+ but normal on API 21-22. -->
    <!-- <uses-permission android:name="android.permission.READ_PHONE_STATE" /> -->

    <application
        android:name=".PushgatewayExporterApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.PushgatewayExporter"
        android:usesCleartextTraffic="true"
        android:networkSecurityConfig="@xml/network_security_config"
        tools:targetApi="34">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.PushgatewayExporter">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- JobScheduler service for periodic metric collection and push -->
        <service
            android:name=".scheduler.MetricsJobService"
            android:permission="android.permission.BIND_JOB_SERVICE"
            android:exported="false" />

        <!-- Boot receiver to re-schedule persisted jobs after reboot -->
        <receiver
            android:name=".scheduler.BootReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

    </application>

</manifest>
